{
  "name": "mrtdown-datamall-mastodon-mirror",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "check": "npm run docs:check && npm run typecheck && npm run lint",
    "docs:check": "node scripts/validate-docs.mjs",
    "dev": "wrangler dev --test-scheduled",
    "dev:invoke": "curl 'http://localhost:8787/__scheduled?cron=*%2F3+*+*+*+*'",
    "format": "biome format --write .",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "typegen": "wrangler types",
    "test": "vitest run"
  },
  "type": "module",
  "author": "",
  "license": "MIT",
  "description": "",
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "26.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "wrangler": "^4.59.1"
  }
}
